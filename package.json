{
  "name": "apple-calendar-mcp",
  "version": "1.1.0",
  "description": "MCP server for Apple Calendar via native EventKit API with proper recurring event support",
  "type": "module",
  "main": "build/index.js",
  "bin": "build/index.js",
  "files": [
    "build/",
    "swift/Sources/",
    "swift/Package.swift",
    "swift/Package.resolved",
    "swift/apple-bridge.entitlements",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "postinstall": "./scripts/postinstall.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "apple",
    "calendar",
    "eventkit",
    "model-context-protocol",
    "claude",
    "macos"
  ],
  "author": "Waldemar Hoffmann <office@w-hoffmann.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w-hoffmann/apple-calendar-mcp.git"
  },
  "homepage": "https://github.com/w-hoffmann/apple-calendar-mcp#readme",
  "bugs": {
    "url": "https://github.com/w-hoffmann/apple-calendar-mcp/issues"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "execa": "^9.5.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
